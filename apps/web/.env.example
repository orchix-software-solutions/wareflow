# Public base URL for the API (relative → proxied via Next rewrites in development)
NEXT_PUBLIC_API_URL=/api/v1

# Origin the Next.js rewrites proxy to (server-side). Must match the API port.
API_ORIGIN=http://localhost:3001

# Optional: override the health-check endpoint used by <HealthIndicator />
NEXT_PUBLIC_HEALTH_URL=/api/health

# Display name for the app
NEXT_PUBLIC_APP_NAME=WareFlow
