# ── App ──
NODE_ENV=development

# ── Web (apps/web) ──
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_NAME=WareFlow

# ── API (apps/api) ──
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# ── Database (PostgreSQL) ──
POSTGRES_USER=wareflow
POSTGRES_PASSWORD=wareflow
POSTGRES_DB=wareflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://wareflow:wareflow@localhost:5432/wareflow

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
