# ── App ──
NODE_ENV=development

# ── Web (apps/web) ──
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_NAME=WareFlow

# ── API (apps/api) ──
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# ── Database (PostgreSQL) ──
POSTGRES_USER=wareflow
POSTGRES_PASSWORD=wareflow
POSTGRES_DB=wareflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://wareflow:wareflow@localhost:5432/wareflow

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── MinIO (Object Storage) ──
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=wareflow
MINIO_SECRET_KEY=wareflow123
MINIO_USE_SSL=false
MINIO_BUCKET=wareflow-assets
MINIO_PUBLIC_URL=http://localhost:9000
